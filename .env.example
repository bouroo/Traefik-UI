# Traefik-UI Configuration
# Copy this file to .env and customize for your deployment

# Server Configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Traefik API Connection
TRAEFIK_API_URL=http://traefik:8080
# TRAEFIK_API_USERNAME=
# TRAEFIK_API_PASSWORD=

# Database
DB_PATH=./data/traefik-ui.db

# Authentication
# IMPORTANT: Change JWT_SECRET to a cryptographically random string (≥ 32 bytes)
# Example: openssl rand -base64 48
JWT_SECRET=change-me-in-production-please
# Set ENCRYPTION_KEY explicitly (do not rely on JWT_SECRET fallback)
# ENCRYPTION_KEY=

# Bootstrap / First-Run Admin
# On first start, when the users table is empty, an admin account is created.
# If ADMIN_PASSWORD is set (non-empty), it is used as the admin password.
# If ADMIN_PASSWORD is unset/empty, a random 12-char password is generated
# and printed once to stdout (NOT to the structured log).
# Recommended for production: set both via your secrets manager / compose env.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# CORS
CORS_ORIGIN=*

# Security Headers
# Enable HSTS only when serving behind HTTPS (Strict-Transport-Security)
# HSTS_ENABLED=false

# Optional: File paths for Traefik integration
# ACCESS_LOG_PATH=/var/log/traefik/access.log
# ACME_JSON_PATH=/etc/traefik/acme.json
# DYNAMIC_CONFIG_PATH=/etc/traefik/dynamic.yml
# STATIC_CONFIG_PATH=/etc/traefik/static.yml
