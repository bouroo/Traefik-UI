{
  "name": "traefik-ui-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A full-featured web UI for managing Traefik reverse proxy - monorepo",
  "type": "module",
  "packageManager": "bun@1.2.4",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"packages/**/*.{ts,js,json,html,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,js,json,html,css}\""
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
